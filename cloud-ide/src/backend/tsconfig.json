{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16", 
    "outDir": "./dist",
    "rootDir": "../", 
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    // 1. Tells TS to load built-in OS modules
    "types": ["node", "jest"],
    
    // 2. The Monorepo Treasure Map (Modernized)
    "paths": {
      "@cloud-ide/shared": ["../shared/index.ts"],
      "@cloud-ide/shared/*": ["../shared/*"]
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/backend/src/server.js",
    "dev": "ts-node -r tsconfig-paths/register src/server.ts", 
    "test": "jest"
  },
  "include": ["src/**/*", "../shared/**/*"]
}