{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "jest"],
    "paths": {
      "@cloud-ide/shared": ["../shared/index.ts"],
      "@cloud-ide/shared/*": ["../shared/*"]
    }
  },
  "include": ["src/**/*"]
}