{
  "name": "cloud-ide-workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently \"npm run dev:sandbox\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspaces --if-present",
    "test": "jest",
    "test:watch": "jest --watchAll"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^8.2.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9"
  }
}